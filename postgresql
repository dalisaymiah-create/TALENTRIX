-- =====================================================
-- FUNCTION TO GET CURRENT SCHOOL YEAR
-- =====================================================

CREATE OR REPLACE FUNCTION get_current_school_year()
RETURNS VARCHAR(20) AS $$
DECLARE
    current_year INTEGER;
    next_year INTEGER;
BEGIN
    current_year := EXTRACT(YEAR FROM CURRENT_DATE);
    next_year := current_year + 1;
    
    -- If current month is June or later, school year is current_year-next_year
    IF EXTRACT(MONTH FROM CURRENT_DATE) >= 6 THEN
        RETURN current_year || '-' || next_year;
    ELSE
        -- Otherwise, previous year-current_year
        RETURN (current_year - 1) || '-' || current_year;
    END IF;
END;
$$ LANGUAGE plpgsql;

