-- Create the database
CREATE DATABASE Bisu_Registry_Achievement_Tracker;

-- Connect to the database
\c Bisu_Registry_Achievement_Tracker;

-- Table: User
CREATE TABLE "User" (
    id SERIAL PRIMARY KEY,
    email VARCHAR(255) NOT NULL UNIQUE,
    password VARCHAR(255) NOT NULL,
    usertype VARCHAR(50) NOT NULL,
    admin_type VARCHAR(50),
    created_at TIMESTAMP WITHOUT TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    first_name VARCHAR(100),
    last_name VARCHAR(100)
);

-- Table: College
CREATE TABLE college (
    id SERIAL PRIMARY KEY,
    college_code VARCHAR(20) NOT NULL UNIQUE,
    college_name VARCHAR(200) NOT NULL,
    description TEXT
);

-- Table: Course
CREATE TABLE course (
    id SERIAL PRIMARY KEY,
    course_code VARCHAR(20) NOT NULL UNIQUE,
    course_name VARCHAR(200) NOT NULL,
    college_id INT NOT NULL,
    FOREIGN KEY (college_id) REFERENCES college(id) ON DELETE CASCADE
);

-- Table: category
CREATE TABLE category (
    id SERIAL PRIMARY KEY,
    category_name VARCHAR(100) NOT NULL,
    category_type VARCHAR(50) NOT NULL
);

-- Table: activity
CREATE TABLE activity (
    id SERIAL PRIMARY KEY,
    activity_name VARCHAR(200) NOT NULL,
    activity_type VARCHAR(100) NOT NULL,
    competition_level VARCHAR(50) DEFAULT 'Intramurals',
    school_year VARCHAR(20),
    CHECK (competition_level IN ('Intramurals', 'Provincial', 'Regional', 'National', 'International'))
);

-- Table: coach
CREATE TABLE coach (
    id SERIAL PRIMARY KEY,
    user_id INT NOT NULL,
    FOREIGN KEY (user_id) REFERENCES "User"(id) ON DELETE CASCADE
);

-- Table: announcement
CREATE TABLE announcement (
    id SERIAL PRIMARY KEY,
    title VARCHAR(200) NOT NULL,
    content TEXT,
    announcement_type VARCHAR(50) NOT NULL,
    author_id INT NOT NULL,
    is_published BOOLEAN DEFAULT false,
    created_at TIMESTAMP WITHOUT TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP WITHOUT TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    image_path TEXT,
    admin_type VARCHAR(50) DEFAULT NULL,
    school_year VARCHAR(20),
    FOREIGN KEY (author_id) REFERENCES "User"(id) ON DELETE CASCADE,
    CHECK (admin_type IN ('sports', 'cultural', NULL))
);

-- Table: contest
CREATE TABLE contest (
    id SERIAL PRIMARY KEY,
    activity_id INT NOT NULL,
    name VARCHAR(200) NOT NULL,
    tournament_manager VARCHAR(200),
    category_id INT NOT NULL,
    contest_status VARCHAR(50) DEFAULT 'active',
    FOREIGN KEY (activity_id) REFERENCES activity(id) ON DELETE CASCADE,
    FOREIGN KEY (category_id) REFERENCES category(id) ON DELETE CASCADE
);

-- Table: team
CREATE TABLE team (
    id SERIAL PRIMARY KEY,
    team_name VARCHAR(200) NOT NULL,
    coach_id INT NOT NULL,
    contest_id INT NOT NULL,
    FOREIGN KEY (coach_id) REFERENCES coach(id) ON DELETE CASCADE,
    FOREIGN KEY (contest_id) REFERENCES contest(id) ON DELETE CASCADE
);

-- Table: student
CREATE TABLE student (
    id SERIAL PRIMARY KEY,
    yr_level INT NOT NULL,
    user_id INT NOT NULL,
    course_id INT NOT NULL,
    FOREIGN KEY (user_id) REFERENCES "User"(id) ON DELETE CASCADE,
    FOREIGN KEY (course_id) REFERENCES course(id) ON DELETE CASCADE,
    CHECK (yr_level BETWEEN 1 AND 5)
);

-- Table: participation
CREATE TABLE participation (
    id SERIAL PRIMARY KEY,
    student_id INT NOT NULL,
    ranking VARCHAR(50),
    created_at TIMESTAMP WITHOUT TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    team_id INT NOT NULL,
    membership_status VARCHAR(50) DEFAULT 'active',
    FOREIGN KEY (student_id) REFERENCES student(id) ON DELETE CASCADE,
    FOREIGN KEY (team_id) REFERENCES team(id) ON DELETE CASCADE
);

