-- Sample student data with course and college
SELECT 
    u.first_name || ' ' || u.last_name as student_name,
    u.email,
    c.course_code,
    c.course_name,
    col.college_code,
    col.college_name,
    s.yr_level as year_level
FROM student s
JOIN "User" u ON s.user_id = u.id
JOIN course c ON s.course_id = c.id
JOIN college col ON c.college_id = col.id
LIMIT 20;

-- Sample participations with rankings
SELECT 
    u.first_name || ' ' || u.last_name as student_name,
    c.course_code,
    col.college_code,
    t.team_name,
    cat.category_name,
    p.ranking,
    p.membership_status
FROM participation p
JOIN student s ON p.student_id = s.id
JOIN "User" u ON s.user_id = u.id
JOIN course c ON s.course_id = c.id
JOIN college col ON c.college_id = col.id
JOIN team t ON p.team_id = t.id
JOIN contest cont ON t.contest_id = cont.id
JOIN category cat ON cont.category_id = cat.id
WHERE p.ranking IS NOT NULL
LIMIT 30;
