-- =====================================================
-- INSERT PARTICIPATIONS WITH RANKINGS (Sample)
-- =====================================================

DO $$
DECLARE
    team_record RECORD;
    student_record RECORD;
    rank_index INT;
    rankings_text TEXT[];
BEGIN
    -- For COS Basketball Warriors (Champion)
    FOR team_record IN SELECT id, team_name FROM team WHERE team_name = 'COS Basketball Warriors' LOOP
        rank_index := 0;
        FOR student_record IN 
            SELECT s.id FROM student s
            JOIN course c ON s.course_id = c.id
            JOIN college col ON c.college_id = col.id
            WHERE col.college_code = 'COS'
            LIMIT 10
        LOOP
            INSERT INTO participation (student_id, team_id, membership_status, created_at, ranking) 
            VALUES (student_record.id, team_record.id, 'active', '2024-08-01'::TIMESTAMP, 'Champion');
        END LOOP;
    END LOOP;
    
    -- For CTE Basketball Titans (1st Runner Up)
    FOR team_record IN SELECT id, team_name FROM team WHERE team_name = 'CTE Basketball Titans' LOOP
        FOR student_record IN 
            SELECT s.id FROM student s
            JOIN course c ON s.course_id = c.id
            JOIN college col ON c.college_id = col.id
            WHERE col.college_code = 'CTE'
            LIMIT 10
        LOOP
            INSERT INTO participation (student_id, team_id, membership_status, created_at, ranking) 
            VALUES (student_record.id, team_record.id, 'active', '2024-08-01'::TIMESTAMP, '1st Runner Up');
        END LOOP;
    END LOOP;
    
    -- For Track and Field - assign individual rankings
    FOR team_record IN SELECT id, team_name FROM team WHERE team_name LIKE 'Track and Field%' LOOP
        rankings_text := ARRAY['1st Place', '2nd Place', '3rd Place', '4th Place', '5th Place', '6th Place', '7th Place', '8th Place'];
        rank_index := 1;
        FOR student_record IN SELECT id FROM student LIMIT 8 LOOP
            INSERT INTO participation (student_id, team_id, membership_status, created_at, ranking) 
            VALUES (student_record.id, team_record.id, 'active', '2024-09-01'::TIMESTAMP, rankings_text[rank_index]);
            rank_index := rank_index + 1;
        END LOOP;
    END LOOP;
    
    -- For Dance Crew (1st Place)
    FOR team_record IN SELECT id, team_name FROM team WHERE team_name = 'COS Dance Crew' LOOP
        FOR student_record IN SELECT id FROM student LIMIT 10 LOOP
            INSERT INTO participation (student_id, team_id, membership_status, created_at, ranking) 
            VALUES (student_record.id, team_record.id, 'active', '2024-09-10'::TIMESTAMP, '1st Place');
        END LOOP;
    END LOOP;
    
    -- For Chorale (2nd Place)
    FOR team_record IN SELECT id, team_name FROM team WHERE team_name = 'BISU Chorale' LOOP
        FOR student_record IN SELECT id FROM student OFFSET 10 LIMIT 15 LOOP
            INSERT INTO participation (student_id, team_id, membership_status, created_at, ranking) 
            VALUES (student_record.id, team_record.id, 'active', '2024-09-10'::TIMESTAMP, '2nd Place');
        END LOOP;
    END LOOP;
    
    -- Add random additional participations
    FOR student_record IN SELECT id FROM student LOOP
        -- Add each student to 1-2 additional random teams
        FOR team_record IN 
            SELECT id FROM team 
            WHERE id NOT IN (SELECT team_id FROM participation WHERE student_id = student_record.id)
            ORDER BY random() 
            LIMIT (floor(random() * 2) + 1)::INT
        LOOP
            INSERT INTO participation (student_id, team_id, membership_status, created_at, ranking) 
            VALUES (student_record.id, team_record.id, 'active', 
                    ('2024-01-01'::TIMESTAMP + (random() * 300)::INT * INTERVAL '1 day'),
                    CASE WHEN random() < 0.3 THEN 
                         CASE floor(random() * 5)::INT
                             WHEN 0 THEN 'Participant'
                             WHEN 1 THEN 'Finalist'
                             WHEN 2 THEN '1st Place'
                             WHEN 3 THEN '2nd Place'
                             ELSE '3rd Place'
                         END
                    ELSE NULL END);
        END LOOP;
    END LOOP;
END $$;

